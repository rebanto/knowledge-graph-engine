# Copy to .env on the server and replace every placeholder before deploy.sh.

GEMINI_API_KEY=<your-gemini-api-key>
LLM_MODEL=gemini-flash-lite-latest

# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=<64-plus-random-hex-chars>

# Empty DOMAIN means HTTP-only mode on port 80, useful before DNS is ready.
# HTTPS mode: DOMAIN=example.com, COOKIE_SECURE=true,
# FRONTEND_ORIGIN=https://example.com
# HTTP mode: DOMAIN=, COOKIE_SECURE=false, FRONTEND_ORIGIN=http://<server-ip>
DOMAIN=
COOKIE_SECURE=true
FRONTEND_ORIGIN=https://<your-domain>
REGISTRATION_ENABLED=true

NEO4J_USER=neo4j
# Use long URL-safe passwords here: letters, numbers, dot, dash, underscore.
# POSTGRES_PASSWORD is interpolated into POSTGRES_URL by docker-compose.prod.yml.
NEO4J_PASSWORD=<strong-neo4j-password>
POSTGRES_USER=kgre
POSTGRES_PASSWORD=<strong-postgres-password>
POSTGRES_DB=kgre

# The prod compose overrides service URLs for containers. These switches keep
# the 2 GB host on the single-node, no-reranker path.
USE_SHARDING=false
USE_RERANKER=false
ALLOW_PRIVATE_SOURCE_URLS=false

ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14

CACHE_TTL_ANSWERS=3600
CACHE_TTL_ROUTE=86400
CACHE_TTL_CYPHER=300
CACHE_TTL_EMBED=604800
CACHE_TTL_INFLUENCE=300

MAX_CYPHER_ATTEMPTS=3
ENTITY_RESOLVE_HIGH=0.97
ENTITY_RESOLVE_LOW=0.55
ENTITY_RESOLVE_ADJUDICATE=true
GRAPH_ALGO_EDGE_LIMIT=10000
MAX_PDF_UPLOAD_MB=25

RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUESTION=20/minute
RATE_LIMIT_DEEP_RESEARCH=3/minute
RATE_LIMIT_SOURCE_MUTATION=20/minute
RATE_LIMIT_AUTH=10/minute
