# Hugging Face Docker Space secrets / variables.
# Set these in the Space settings UI; do not commit real values.

GEMINI_API_KEY=
AUTH_SECRET_KEY=
LLM_MODEL=gemini-flash-lite-latest

# Neo4j AuraDB Free. The official Neo4j driver handles neo4j+s natively.
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Neon Postgres pooled connection string. Keep sslmode=require.
POSTGRES_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# In-container services inside the Space.
REDIS_URL=redis://127.0.0.1:6379
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_BACKUP_PATH=/data/chroma

# Private Hugging Face Dataset repo used for Chroma snapshots.
HF_TOKEN=
CHROMA_BACKUP_REPO=<username>/kgre-chroma-backup
CHROMA_BACKUP_DEBOUNCE_SECONDS=300
CHROMA_BACKUP_INTERVAL_SECONDS=86400

# Same-origin cookies and app URL. Use the direct Space URL, not the embedded iframe.
FRONTEND_ORIGIN=https://<user>-<space>.hf.space
COOKIE_SECURE=true
REGISTRATION_ENABLED=true
STATIC_DIR=/app/frontend_dist

# Production retrieval and deployment shape.
USE_RERANKER=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_SHARDING=false

# Security and rate limits.
ALLOW_PRIVATE_SOURCE_URLS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUESTION=30/minute
RATE_LIMIT_DEEP_RESEARCH=6/minute
RATE_LIMIT_SOURCE_MUTATION=30/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_KEEPALIVE=30/minute

# Idempotent public demo bootstrap. ArXiv feed URLs are categories/queries sent
# only to the ArXiv API; the SSRF guard applies to user-supplied rss/web_url
# sources, not these internal category strings or localhost Redis/Chroma.
BOOTSTRAP_DEMO=arxiv_seed
BOOTSTRAP_ARXIV_QUERY=cs.AI,cs.LG,cs.CL
# Papers fetched per arXiv source. Keep this small on the free Space: each paper
# costs several free-tier Gemini extraction calls, and a big first-boot batch can
# outrun the ingestion timeout / 15-min stuck detector and show as "crashed".
ARXIV_MAX_RESULTS=10
