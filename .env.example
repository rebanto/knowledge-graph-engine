GEMINI_API_KEY=

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kgre_dev_password

POSTGRES_USER=kgre
POSTGRES_PASSWORD=kgre_dev_password
POSTGRES_DB=kgre
POSTGRES_URL=postgresql://kgre:kgre_dev_password@localhost:5432/kgre

REDIS_URL=redis://localhost:6379

CHROMA_PERSIST_DIR=./chroma_data

# ChromaDB server (REQUIRED for the dev/prod stack). The API and the ingestion
# worker are separate processes and MUST share one Chroma server — an in-process
# client can't see another process's writes. dev.ps1 starts the kgre-chroma
# container (host port 8001 → container 8000). Leave CHROMA_HOST unset only for
# the offline seed script / unit tests (single-process embedded PersistentClient).
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Phase 3 — distributed worker pool (docker compose --profile distributed)
COORDINATOR_HOST=coordinator
COORDINATOR_PORT=50051

# Phase 4 — sharded Neo4j (docker compose --profile sharding)
USE_SHARDING=true
NUM_SHARDS=3
NEO4J_SHARD_0_URI=bolt://localhost:7687
NEO4J_SHARD_1_URI=bolt://localhost:7688
NEO4J_SHARD_2_URI=bolt://localhost:7689

# LLM model selection
LLM_MODEL=gemini-flash-lite-latest

# Logging
LOG_LEVEL=INFO

# Cache TTLs (seconds)
CACHE_TTL_ANSWERS=3600
CACHE_TTL_ROUTE=86400
CACHE_TTL_CYPHER=300
CACHE_TTL_EMBED=604800
CACHE_TTL_INFLUENCE=300   # cached PageRank / community results per workspace

# Retrieval quality — see docs/04-configuration.md and docs/18-evaluation.md
USE_RERANKER=true                                       # cross-encoder rerank of vector hits
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_FETCH_MULTIPLIER=3                               # over-fetch factor before reranking
MAX_CYPHER_ATTEMPTS=3                                   # text-to-Cypher self-correction budget

# Entity resolution thresholds (three-band: merge / adjudicate / new)
ENTITY_RESOLVE_HIGH=0.90        # cosine ≥ this auto-merges
ENTITY_RESOLVE_LOW=0.82         # cosine in [LOW, HIGH) is sent to the LLM adjudicator
ENTITY_RESOLVE_ADJUDICATE=true  # off → treat borderline pairs as non-matches

# Graph algorithms
GRAPH_ALGO_EDGE_LIMIT=20000     # max edges pulled into networkx for PageRank/communities

# Conversations (multi-turn follow-ups) — see docs/17-conversations.md
CONV_WINDOW_TURNS=6      # recent turns kept verbatim in the context window
CONV_CONTEXT_CHARS=6000  # hard cap on the assembled conversation history
CONV_ANSWER_CHARS=600    # per-turn answer trim length inside the history
